generator client {
  provider = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [pg_trgm]
}

enum AuthProvider {
  email
  google
  apple
}

enum GroupType {
  trip
  home
  couple
  other
}

enum GroupRole {
  owner
  admin
  member
}

enum SplitType {
  equal
  percentage
  shares
  exact
  adjustment
}

enum RecurrenceType {
  weekly
  biweekly
  monthly
  custom
}

enum FriendshipStatus {
  pending
  accepted
  rejected
  blocked
}

model User {
  id                   Int       @id @default(autoincrement())
  name                 String    @db.VarChar(100)
  email                String    @unique @db.VarChar(150)
  passwordHash         String?   @map("password_hash") @db.VarChar(255)
  provider             AuthProvider @default(email)
  googleId             String?   @unique @map("google_id") @db.VarChar(255)
  appleId              String?   @unique @map("apple_id") @db.VarChar(255)
  defaultCurrency      String    @default("USD") @map("default_currency") @db.Char(3)
  onboardingCompleted  Boolean   @default(false) @map("onboarding_completed")
  avatarUrl            String?   @map("avatar_url") @db.VarChar(500)
  termsAcceptedAt      DateTime? @map("terms_accepted_at") @db.Timestamptz
  termsVersion         String?   @map("terms_version") @db.VarChar(20)
  acceptedTermsAt      DateTime? @map("accepted_terms_at") @db.Timestamptz
  acceptedTermsVersion String?   @map("accepted_terms_version") @db.VarChar(50)
  timezone             String    @default("UTC") @db.VarChar(50)
  pushToken            String?   @map("push_token") @db.VarChar(255)
  lastSeenAt           DateTime? @map("last_seen_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  sessions             Session[]
  groupsCreated        Group[]
  memberships          GroupMember[]
  defaultSplits        GroupDefaultSplit[]
  invitesSent          GroupInvitation[]
  expensesPaid         Expense[]
  splitsOwed           ExpenseSplit[]
  settlementsPaid      Settlement[] @relation("PayerRelation")
  settlementsReceived  Settlement[] @relation("PayeeRelation")
  comments             ExpenseComment[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  offlineQueueItems    OfflineQueue[]
  balancesAsUser       Balance[] @relation("UserBalance")
  balancesAsCounter    Balance[] @relation("CounterpartBalance")
  friendsRequested     Friendship[] @relation("Requester")
  friendsAddressing    Friendship[] @relation("Addressee")

  @@map("users")
}

model Session {
  id               String   @id @default(uuid())
  userId           Int      @map("user_id")
  refreshTokenHash String   @unique @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?  @map("user_agent")
  ipAddress        String?  @map("ip_address")
  lastUsedAt       DateTime @map("last_used_at") @db.Timestamptz
  expiresAt        DateTime @map("expires_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([lastUsedAt])
  @@map("sessions")
}

model Group {
  id                 Int       @id @default(autoincrement())
  name               String    @db.VarChar(150)
  type               GroupType @default(other)
  coverPhotoUrl      String?   @map("cover_photo_url") @db.VarChar(500)
  createdBy          Int       @map("created_by")
  groupCurrency      String    @default("USD") @map("group_currency") @db.Char(3)
  simplifiedSettlement Boolean @default(true) @map("simplified_settlement")
  settlementThreshold Int      @default(0) @map("settlement_threshold")
  defaultSplitType   SplitType @default(equal) @map("default_split_type")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  // Relations
  creator            User      @relation(fields: [createdBy], references: [id])
  members            GroupMember[]
  defaultSplits      GroupDefaultSplit[]
  invitations        GroupInvitation[]
  expenses           Expense[]
  settlements        Settlement[]
  auditLogs          AuditLog[]

  @@index([createdAt(sort: Desc)])
  @@map("groups")
}

model GroupMember {
  groupId  Int       @map("group_id")
  userId   Int       @map("user_id")
  role     GroupRole @default(member)
  joinedAt DateTime  @default(now()) @map("joined_at") @db.Timestamptz

  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@index([groupId])
  @@index([userId])
  @@unique([groupId, userId], name: "idx_group_members_group_user")
  @@map("group_members")
}

model Friendship {
  id          Int              @id @default(autoincrement())
  requesterId Int              @map("requester_id")
  addresseeId Int              @map("addressee_id")
  status      FriendshipStatus @default(pending)
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  requester   User             @relation("Requester", fields: [requesterId], references: [id])
  addressee   User             @relation("Addressee", fields: [addresseeId], references: [id])

  @@unique([requesterId, addresseeId])
  @@index([requesterId, status])
  @@index([addresseeId, status])
  @@map("friendships")
}

model GroupDefaultSplit {
  id         Int       @id @default(autoincrement())
  groupId    Int       @map("group_id")
  userId     Int       @map("user_id")
  percentage Decimal?  @db.Decimal(5,2)
  shareCount Int       @default(1) @map("share_count")

  group      Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_default_splits")
}

model GroupInvitation {
  id           Int       @id @default(autoincrement())
  groupId      Int       @map("group_id")
  invitedBy    Int       @map("invited_by")
  tokenHash    String    @unique @map("token_hash") @db.VarChar(255)
  invitedEmail String?   @map("invited_email") @db.VarChar(150)
  expiresAt    DateTime  @map("expires_at") @db.Timestamptz
  acceptedAt   DateTime? @map("accepted_at") @db.Timestamptz
  isRevoked    Boolean   @default(false) @map("is_revoked")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  group        Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  inviter      User      @relation(fields: [invitedBy], references: [id])

  @@index([groupId, isRevoked, expiresAt])
  @@map("group_invites")
}

model Expense {
  id                   Int       @id @default(autoincrement())
  groupId              Int?      @map("group_id")
  title                String    @db.VarChar(150)
  totalAmount          Int       @map("total_amount") // stored in cents
  originalCurrency     String    @default("USD") @map("original_currency") @db.Char(3)
  exchangeRateSnapshot Decimal   @default(1.0) @map("exchange_rate_snapshot") @db.Decimal(15,6)
  categoryId           Int?      @map("category_id")
  paidBy               Int       @map("paid_by")
  receiptImageUrl      String?   @map("receipt_image_url") @db.VarChar(500)
  isRecurring          Boolean   @default(false) @map("is_recurring")
  recurrenceType       RecurrenceType? @map("recurrence_type")
  recurrenceDay        Int?      @map("recurrence_day") @db.SmallInt
  nextDueDate          DateTime? @map("next_due_date") @db.Date
  recurringTemplateId  Int?      @map("recurring_template_id")
  idempotencyKey       String?   @unique @map("idempotency_key") @db.VarChar(64)
  createdBy            Int?      @map("created_by") // For standalone expenses
  createdAt            DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt            DateTime? @map("deleted_at") @db.Timestamptz

  group                Group?    @relation(fields: [groupId], references: [id])
  payer                User      @relation(fields: [paidBy], references: [id])
  category             ExpenseCategory? @relation(fields: [categoryId], references: [id])
  parentExpense        Expense?  @relation("RecurringRelation", fields: [recurringTemplateId], references: [id])
  childExpenses        Expense[] @relation("RecurringRelation")
  splits               ExpenseSplit[]
  comments             ExpenseComment[]

  @@index([groupId, createdAt(sort: Desc)])
  @@index([createdBy, createdAt(sort: Desc)])
  @@index([deletedAt])
  @@index([recurringTemplateId])
  @@map("expenses")
}

model ExpenseSplit {
  id               Int       @id @default(autoincrement())
  expenseId        Int       @map("expense_id")
  userId           Int       @map("user_id")
  owedAmount       Int       @map("owed_amount") // cents
  paidAmount       Int       @default(0) @map("paid_amount") // for multi-payer
  shareCount       Int       @default(1) @map("share_count") @db.SmallInt
  adjustmentAmount Int       @default(0) @map("adjustment_amount")

  expense          Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user             User      @relation(fields: [userId], references: [id])

  @@index([expenseId])
  @@index([userId])
  @@map("expense_splits")
}

model Settlement {
  id               Int       @id @default(autoincrement())
  payerId          Int       @map("payer_id")
  payeeId          Int       @map("payee_id")
  amount           Int       @map("amount") // cents
  currency         String    @default("USD") @db.Char(3)
  groupId          Int?      @map("group_id")
  idempotencyKey   String?   @unique @map("idempotency_key") @db.VarChar(64)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  payer            User      @relation("PayerRelation", fields: [payerId], references: [id])
  payee            User      @relation("PayeeRelation", fields: [payeeId], references: [id])
  group            Group?    @relation(fields: [groupId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
  @@index([payerId, payeeId, createdAt(sort: Desc)])
  @@index([payeeId, createdAt(sort: Desc)])
  @@map("settlements")
}

model Balance {
  id               Int       @id @default(autoincrement())
  userId           Int       @map("user_id")
  counterpartId    Int       @map("counterpart_id")
  netBalance       Int       @map("net_balance") // Positive if user is owed, negative if user owes
  currency         String    @default("USD") @db.Char(3)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  user             User      @relation("UserBalance", fields: [userId], references: [id], onDelete: Cascade)
  counterpart      User      @relation("CounterpartBalance", fields: [counterpartId], references: [id], onDelete: Cascade)

  @@unique([userId, counterpartId])
  @@index([userId])
  @@map("balances")
}

model ExpenseComment {
  id           Int       @id @default(autoincrement())
  expenseId    Int       @map("expense_id")
  userId       Int       @map("user_id")
  commentText  String?   @map("comment_text") @db.Text
  imageUrl     String?   @map("image_url") @db.VarChar(500)
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz

  expense      Expense   @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expenseId, createdAt(sort: Asc)])
  @@map("expense_comments")
}

model Notification {
  id             Int       @id @default(autoincrement())
  recipientId    Int       @map("recipient_id")
  title          String    @db.VarChar(100)
  body           String    @db.Text
  referenceType  String    @map("reference_type") // 'expense','settlement','group_invite','comment','reminder'
  referenceId    Int?      @map("reference_id")
  isRead         Boolean   @default(false) @map("is_read")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  recipient      User      @relation(fields: [recipientId], references: [id], onDelete: Cascade)

  @@index([recipientId, createdAt(sort: Desc)])
  @@index([recipientId, isRead])
  @@map("notifications")
}

model AuditLog {
  id             Int       @id @default(autoincrement())
  actorId        Int?      @map("actor_id")
  action         String    // 'create','update','delete','restore'
  entityType     String    @map("entity_type") @db.VarChar(50)
  entityId       Int       @map("entity_id")
  groupId        Int?      @map("group_id")
  beforeSnapshot Json?     @map("before_snapshot")
  afterSnapshot  Json?     @map("after_snapshot")
  ipAddress      String?   @map("ip_address") @db.Inet
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  actor          User?     @relation(fields: [actorId], references: [id])
  group          Group?    @relation(fields: [groupId], references: [id])

  @@index([groupId, createdAt(sort: Desc)])
  @@index([actorId, createdAt(sort: Desc)])
  @@map("audit_log")
}

model OfflineQueue {
  id             Int       @id @default(autoincrement())
  userId         Int       @map("user_id")
  actionType     String    @map("action_type") // e.g., 'create_expense'
  payload        Json      
  status         String    @default("pending") // 'pending', 'processing', 'failed', 'completed'
  errorMessage   String?   @map("error_message") @db.Text
  idempotencyKey String    @unique @map("idempotency_key") @db.VarChar(64)
  dependencyIds  String[]  @map("dependency_ids") // Array of earlier queue IDs
  maxRetry       Int       @default(3) @map("max_retry")
  retryCount     Int       @default(0) @map("retry_count")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt(sort: Asc)])
  @@map("offline_queue")
}

model EmailQueue {
  id             Int       @id @default(autoincrement())
  toEmail        String    @map("to_email") @db.VarChar(150)
  subject        String    @db.VarChar(255)
  template       String    @db.VarChar(100)
  templateData   Json      @default("{}") @map("template_data")
  status         String    @default("pending") // 'pending','sent','failed'
  attempts       Int       @default(0) @db.SmallInt
  lastError      String?   @map("last_error") @db.Text
  scheduledAt    DateTime  @default(now()) @map("scheduled_at") @db.Timestamptz
  sentAt         DateTime? @map("sent_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@index([status, scheduledAt])
  @@map("email_queue")
}

model ExpenseCategory {
  id             Int       @id
  name           String    @db.VarChar(50)
  icon           String    @db.VarChar(50)

  expenses       Expense[]

  @@map("expense_categories")
}

model ExchangeRate {
  fromCurrency   String    @map("from_currency") @db.Char(3)
  toCurrency     String    @map("to_currency") @db.Char(3)
  rate           Decimal   @db.Decimal(15,6)
  fetchedAt      DateTime  @map("fetched_at") @db.Timestamptz

  @@id([fromCurrency, toCurrency])
  @@index([fetchedAt(sort: Desc)])
  @@map("exchange_rates")
}

model PasswordReset {
  email          String    @id @db.VarChar(150)
  tokenHash      String    @map("token_hash") @db.VarChar(255)
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz

  @@map("password_resets")
}

model AppVersion {
  id             Int       @id @default(autoincrement())
  platform       String    // 'ios','android','web'
  minVersion     String    @map("min_version") @db.VarChar(20)
  forceUpdate    Boolean   @default(false) @map("force_update")
  updatedAt      DateTime  @default(now()) @map("updated_at") @db.Timestamptz

  @@map("app_versions")
}
