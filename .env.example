# ─── SplitEase Docker Environment ───
# Copy this file to .env and fill in your values

# PostgreSQL
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=splitease

# Backend
NODE_ENV=development
DATABASE_URL=postgresql://admin:changeme@postgres:5432/splitease?schema=public
REDIS_URL=redis://redis:6379
JWT_SECRET=changeme_use_a_strong_random_string
BACKEND_PORT=3000
EXCHANGE_RATE_API_KEY=

# Frontend (used at build time)
# For Cloudflare Tunnel, set this to your public tunneled domain:
API_URL=https://yourdomain.com/api

# CORS (comma-separated origins, leave empty for defaults)
CORS_ORIGINS=https://yourdomain.com
